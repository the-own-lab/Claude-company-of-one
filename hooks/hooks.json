{
  "description": "Company of One shared hooks for Claude Code and Codex session continuity",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"hooks/scripts/session-start.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"hooks/scripts/pre-compact.sh\""
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"hooks/scripts/post-compact.sh\""
          }
        ]
      }
    ]
  }
}
